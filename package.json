{
  "name": "backend-eglise",
  "version": "1.0.0",
  "description": "API de gestion pour église - Membres, finances, rapports",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "build": "prisma generate",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "db:backup": "node scripts/backup-restore.js export",
    "db:restore": "node scripts/backup-restore.js import",
    "db:sync": "node scripts/backup-restore.js sync",
    "db:migrate:local": "npx prisma db push --schema=prisma/schema.prisma"
  },
  "keywords": [
    "eglise",
    "gestion",
    "api",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "Votre Nom",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.17.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
